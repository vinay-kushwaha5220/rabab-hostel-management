# ============================================================================
# ROOT .gitignore - Rabab Stay Hostel Management System
# ============================================================================

# ============================================================================
# ENVIRONMENT & SECRETS
# ============================================================================
.env
.env.local
.env.*.local
.env.production.local
.env.test.local
.env.development.local

# ============================================================================
# NODE & DEPENDENCIES
# ============================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

# ============================================================================
# BUILD & DIST
# ============================================================================
dist/
dist-ssr/
build/
*.local
.next/
out/

# ============================================================================
# IDE & EDITOR
# ============================================================================
.vscode/
!.vscode/extensions.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
*~
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# ============================================================================
# OS SPECIFIC
# ============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ============================================================================
# DATABASE
# ============================================================================
*.db
*.db-journal
*.sqlite
*.sqlite3
*.db.backup
*.db-backup

# ============================================================================
# LOGS
# ============================================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
lerna-debug.log*

# ============================================================================
# TEMPORARY FILES
# ============================================================================
tmp/
temp/
*.tmp
*.bak
*.swp
*.swo
*~

# ============================================================================
# TESTING
# ============================================================================
coverage/
.nyc_output/
*.lcov

# ============================================================================
# PRISMA
# ============================================================================
/src/generated/prisma
prisma/dev.db
prisma/dev.db-journal

# ============================================================================
# VITE
# ============================================================================
.vite/

# ============================================================================
# TYPESCRIPT
# ============================================================================
*.tsbuildinfo
dist/
build/

# ============================================================================
# MISC
# ============================================================================
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
.turbo/
.turbopack/

# ============================================================================
# MOBILE TESTING (Local development only)
# ============================================================================
# Note: .env files for mobile testing are in .gitignore
# Keep setup scripts but not the generated .env files

# ============================================================================
# DOCUMENTATION GENERATED
# ============================================================================
# Keep documentation files but ignore generated ones
docs/generated/

# ============================================================================
# BACKUP FILES
# ============================================================================
*.backup
*.bak
*.old
*.orig
legacy_backup/

# ============================================================================
# LOCK FILES (Optional - uncomment if you want to commit lock files)
# ============================================================================
# package-lock.json
# yarn.lock
# pnpm-lock.yaml
