# ============================================================================
*.db
*.db-journal
*.sqlite
*.sqlite3
*.db.backup
*.db-backup
dev.db
dev.db-journal
prisma/dev.db
prisma/dev.db-journal

# ============================================================================
# PRISMA
# ============================================================================
/src/generated/prisma
prisma/dev.db
prisma/dev.db-journal

# ============================================================================
