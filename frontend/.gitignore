# ============================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ============================================================================
# BUILD & DIST
# ============================================================================
dist/
dist-ssr/
build/
*.local
.next/
out/

# ============================================================================
# ENVIRONMENT FILES (SENSITIVE DATA)
# ============================================================================
.env
.env.*
.env.local
.env.*.local
.env.production.local
.env.test.local
.env.development.local
.env.network
.env.production

# Note: Keep .env.example or .env.template for reference (not in this repo)

# ============================================================================
# IDE & EDITOR
# ============================================================================
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
*~
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# ============================================================================
# OS SPECIFIC
# ============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ============================================================================
# LOGS
# ============================================================================
logs/
*.log

# ============================================================================
# VITE
# ============================================================================
.vite/

# ============================================================================
# TYPESCRIPT
# ============================================================================
*.tsbuildinfo

# ============================================================================
# TESTING
# ============================================================================
coverage/
.nyc_output/
*.lcov

# ============================================================================
